# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite):
#   DATABASE_URL="file:./dev.db"
# Production (Supabase Postgres — use the "Session mode" pooler URL from
#   Supabase Dashboard → Settings → Database → Connection string):
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL="http://localhost:5173"
APP_URL="http://localhost:3001"

# ── File storage (Supabase Storage) ───────────────────────────────────────────
# Leave blank in local dev to use local disk under ./uploads
# In production, set all three:
#   SUPABASE_URL  — Supabase Dashboard → Settings → API → Project URL
#   SUPABASE_SERVICE_KEY — Settings → API → service_role secret key
#   SUPABASE_BUCKET — name of the Storage bucket you created (e.g. "recordings")
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
SUPABASE_BUCKET="recordings"

# ── External APIs (future milestones) ─────────────────────────────────────────
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# ── Email alerts (future milestones) ──────────────────────────────────────────
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""
# ALERT_EMAIL=""
